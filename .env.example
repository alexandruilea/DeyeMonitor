# ========================================
# DEYE INVERTER CONFIGURATION
# ========================================
# Model: SUN-16K-SG05LP3-EU-SM2 (16kW Hybrid Inverter)
# Change these values to match your inverter model and network setup
DEYE_IP=192.168.0.xxx
DEYE_LOGGER_SERIAL=0000000000
DEYE_PORT=8899
DEYE_MODEL=SUN-16K-SG05LP3-EU-SM2

# Inverter-Specific Power Limits (Model: SUN-16K-SG05LP3-EU-SM2)
# Adjust these values if you have a different inverter model
DEYE_MAX_UPS_TOTAL_POWER=16000  # Maximum UPS/Backup port total output across all 3 phases (W)
DEYE_PHASE_MAX=7000             # Maximum safe power per phase (W) - prevents overload
DEYE_SAFETY_LV=185.0            # Critical low voltage threshold (V) - emergency shutdown
DEYE_MAX_CHARGE_AMPS_LIMIT=185      # Hardware maximum charging current limit (A) - model dependent
DEYE_MAX_DISCHARGE_AMPS_LIMIT=185   # Hardware maximum discharging current limit (A) - model dependent

# Default Battery Charge/Discharge Current Settings
# These are the initial values shown in the UI when the application starts
DEYE_DEFAULT_MAX_CHARGE_AMPS=60       # Default max charging current (A)
DEYE_DEFAULT_GRID_CHARGE_AMPS=40      # Default grid-to-battery charging current (A)
DEYE_DEFAULT_MAX_DISCHARGE_AMPS=150   # Default max discharging current (A)

# Work Mode & Write Throttling
DEYE_ZERO_EXPORT_MODE=2               # Zero export mode: 1=Zero Export to Load (internal CT), 2=Zero Export to CT (external CT)
DEYE_MIN_REGISTER_WRITE_INTERVAL=30   # Minimum seconds between writes to the same register (reduces inverter flash wear)

# ========================================
# DEFAULT SCHEDULE ROWS
# ========================================
# Format: SCHEDULE_N=HH:MM-HH:MM,max_charge,grid_charge,max_discharge,sell|nosell,sell_power
# These are pre-loaded into the schedule panel at startup.
# Remove or comment out to start with an empty schedule.
#
# WARNING: When sell=sell, the inverter switches to "Selling First" work mode.
# In this mode the inverter IGNORES the CT clamp readings, meaning any loads
# that are usually read by the CT clamps (e.g. EV chargers, heat pumps) will NOT
# be accounted for. The inverter will export up to sell_power watts regardless
# of what those loads are consuming. Only loads wired directly through the
# inverter's UPS output are visible. When the sell window ends, the inverter
# returns to Zero Export mode and CT clamp readings are restored.
SCHEDULE_1=23:00-06:00,40,40,185,sell,500
SCHEDULE_2=06:00-09:00,40,40,185,sell,1000
SCHEDULE_3=09:00-18:00,40,40,185,nosell,8000
SCHEDULE_4=18:00-23:00,40,40,185,sell,1000

# Inverter-Specific Register Addresses (Model: SUN-16K-SG05LP3-EU-SM2)
# ⚠️ IMPORTANT: These register addresses are specific to the SUN-16K-SG05LP3-EU-SM2 model
# If you have a different Deye inverter model, you MUST update these addresses!
# Consult your inverter's Modbus register documentation

# Main register block (contains UPS loads, battery data, PV data)
DEYE_MAIN_BASE=588              # Base address for main register block
DEYE_MAIN_COUNT=90              # Number of registers to read from main block
DEYE_UPS_LOAD_L1_OFFSET=62      # Offset within main block for UPS L1 load (register 650)
DEYE_UPS_LOAD_L2_OFFSET=63      # Offset within main block for UPS L2 load (register 651)
DEYE_UPS_LOAD_L3_OFFSET=64      # Offset within main block for UPS L3 load (register 652)
DEYE_BATTERY_SOC_OFFSET=0       # Offset within main block for battery SOC% (register 588)
DEYE_BATTERY_VOLTAGE_OFFSET=36  # Offset within main block for battery voltage (register 624)

# Grid CT register block (contains grid loads from smart meter)
DEYE_GRID_CT_BASE=160           # Base address for grid CT register block
DEYE_GRID_CT_COUNT=35           # Number of registers to read from grid CT block
DEYE_GRID_LOAD_L1_OFFSET=19     # Offset within grid CT block for Grid L1 load (register 179)
DEYE_GRID_LOAD_L2_OFFSET=20     # Offset within grid CT block for Grid L2 load (register 180)
DEYE_GRID_LOAD_L3_OFFSET=21     # Offset within grid CT block for Grid L3 load (register 181)

# Inverter Write Control Registers (Model: SUN-16K-SG05LP3-EU-SM2)
# ⚠️ These register addresses may vary by inverter model - check your documentation!
DEYE_REG_MAX_CHARGE_AMPS=108        # Max charging current from any source (0-185A)
DEYE_REG_MAX_DISCHARGE_AMPS=109     # Max discharging current (0-185A)
DEYE_REG_GRID_CHARGE_ENABLE=130     # Enable grid charging (1=enable, 0=disable)
DEYE_REG_GRID_CHARGE_CURRENT=128    # Grid charge battery current (0-185A)
DEYE_REG_SOLAR_SELL_SLOT1=145       # Solar sell for time slot 1 (1=enable, 0=disable)
DEYE_REG_GRID_CHARGE_SLOT1=172      # Grid charge for time slot 1 (1=enable, 0=disable)
DEYE_REG_CHARGE_TARGET_SOC=166      # Target SOC for charging (%)
DEYE_REG_MAX_GRID_POWER=143         # Limit max grid power output (0-8000W)
DEYE_REG_MAX_SOLAR_SELL_POWER=143   # Max grid export power limit (W)

# ========================================
# OVERPOWER PROTECTION SETTINGS
# ========================================
# Automatically increases charging to absorb excess power when:
# - Export power approaches the max sell power limit
# - Phase voltage exceeds the warning threshold
# This helps prevent inverter shutdown due to grid overvoltage or power limits.

PROTECTION_MAX_SELL_POWER=8000               # Max export power limit in Watts (updated from inverter at startup)
PROTECTION_POWER_THRESHOLD_PCT=95            # Start protection when export exceeds this % of max
PROTECTION_RECOVERY_THRESHOLD_PCT=85         # Reduce protection when export drops below this %
PROTECTION_VOLTAGE_WARNING=251.5             # Start protection when any phase voltage exceeds this (V)
PROTECTION_VOLTAGE_RECOVERY=249.0            # Reduce protection when voltage drops below this (V)
PROTECTION_CHARGE_STEP=10                    # Minimum step size in Amps (used for fine-tuning near thresholds)
PROTECTION_ADJUSTMENT_INTERVAL=60            # Seconds between charge adjustments (allows system to stabilize)
PROTECTION_ENABLED_AT_STARTUP=false          # Enable battery boost protection automatically at startup (true/false)
PROTECTION_BATTERY_NOMINAL_VOLTAGE=52        # Nominal battery voltage for proportional amp calculation (V)
PROTECTION_VOLTAGE_HOLD_MARGIN=5.0           # Hold boost if voltage is within this many V of warning threshold (prevents export recovery from undoing voltage-driven boosts)

# ========================================
# SUNSET CHARGING SETTINGS
# ========================================
# Dynamically adjusts charging speed throughout the day to ensure the battery
# reaches the target SOC by sunset. Uses astronomical calculations (no internet needed).
# The algorithm calculates: required_amps = remaining_ah / hours_until_deadline
# and boosts charging only when the base rate is insufficient.

SOLAR_LATITUDE=47.29                         # Your location latitude (Bocsa, Salaj, Romania)
SOLAR_LONGITUDE=22.91                        # Your location longitude
BATTERY_CAPACITY_AH=600                      # Total battery capacity in Amp-hours
SUNSET_TARGET_SOC=100                        # Target SOC to reach by sunset (%)
SUNSET_BUFFER_MINUTES=60                     # Finish charging this many minutes BEFORE sunset
SUNSET_MIN_CHARGE_AMPS=10                    # Minimum charge rate (your morning export-friendly default)
SUNSET_PEAK_SOLAR_HOUR=0                     # Hour of peak solar production in local time (e.g. 13.5 = 1:30 PM). 0 = auto (solar noon). Bias charging towards this hour for non-south-facing panels.
SUNSET_PEAK_EXPECTED_KW=0                    # Peak clear-sky PV output in kW (e.g. 14). 0 = disabled (no cloudy day compensation).
SUNSET_CLOUD_THRESHOLD_PCT=60                # Below this % of expected PV production → apply cloudy boost (default 60%)
SUNSET_CLOUD_MAX_BOOST=3.0                   # Maximum cloudy-day boost multiplier (default 3x)
SUNSET_CHARGING_ENABLED=true                 # Enable sunset-aware charging at startup (true/false)
SUNSET_WEATHER_ENABLED=true                  # Use Open-Meteo weather forecast for predictive charging (true/false)
SUNSET_WEATHER_REFRESH_HOURS=3               # How often to refresh the forecast (hours)

# ========================================
# EV SMART CHARGER (TUYA)
# ========================================
# Controls a Tuya-based EV charger locally (no cloud needed).
# Adjusts amperage and on/off state based on battery SOC and solar export.
# All changes are rate-limited to one change per cooldown period to avoid
# "shocking" the car with rapid switching.
#
# To get your Device ID, IP, and Local Key, use the tinytuya wizard:
#   python -m tinytuya wizard
#
# The DP (Data Point) IDs vary by charger model. Common mappings:
#   DP 1  = switch (on/off)        — most chargers use DP 1
#   DP 6  = current setting (amps) — check your charger's Tuya developer portal
# If your charger reports amps×10 or milliamps, set DP_AMPS_SCALE accordingly.

EV_CHARGER_ENABLED=false                     # Enable EV charger control at startup (true/false)
EV_CHARGER_DEVICE_ID=your_device_id          # Tuya Device ID (from tinytuya wizard)
EV_CHARGER_IP=192.168.0.xxx                  # Charger IP address on your local network
EV_CHARGER_LOCAL_KEY=your_local_key          # Tuya Local Key (from tinytuya wizard)
EV_CHARGER_PROTOCOL_VERSION=3.3              # Tuya protocol version (3.3 or 3.4 for most devices)

# Amperage Limits
EV_CHARGER_MIN_AMPS=8                        # Minimum charging current (A)
EV_CHARGER_MAX_AMPS=32                       # Maximum charging current (A)

# Battery SOC Thresholds
EV_CHARGER_STOP_SOC=20                       # Stop EV charging when home battery drops below this SOC (%)
EV_CHARGER_START_SOC=80                      # Only start EV charging when home battery is above this SOC (%)

# Solar Follow Mode
EV_CHARGER_SOLAR_MODE=false                  # Scale amps based on solar export surplus (true/false)
                                             # When enabled, amps = export_watts / 230V, clamped to min/max

# Rate Limiting
EV_CHARGER_CHANGE_INTERVAL=5                 # Minutes between charger state changes (on/off or amp adjustment)
                                              # Prevents rapid cycling that can confuse the car's onboard charger

# Battery Pacing
EV_CHARGER_CHARGE_BY_HOUR=7                  # Target hour (0-23) to finish charging by. At night the charger
                                              # paces amps so the house battery lasts until this hour.

# Grid Charge Mode
EV_CHARGER_GRID_CHARGE_AMPS=20               # Amps to use when "Grid charge" mode is enabled (default 20A)

# Solar Ramp-Down Protection
EV_CHARGER_SOLAR_RAMP_DOWN_DELAY=5            # Minutes between solar ramp-down steps (prevents frequent charger restarts)
EV_CHARGER_SOLAR_AMP_STEPS=8,16,24,32         # Significant amp levels for ramp-down (avoids changing by 1A at a time)
EV_CHARGER_EV_FIRST=false                      # Priority: true=EV gets battery charge power too, false=battery charges first

# Tuya DPS Mapping (charger model-specific)
EV_CHARGER_DP_SWITCH=1                       # Data Point ID for on/off switch
EV_CHARGER_DP_AMPS=6                         # Data Point ID for current setting
EV_CHARGER_DP_STATE=124                      # Data Point ID for charger state string (e.g. "Charging", "CloseCharging")
EV_CHARGER_DP_AMPS_SCALE=1                   # Scale factor: 1=amps, 10=amps×10, 1000=milliamps

# Tuya Cloud API Fallback
# If local connection fails repeatedly, the charger falls back to cloud control.
# Get credentials from https://platform.tuya.com → Cloud → your project
TUYA_CLOUD_API_KEY=                          # Tuya IoT Platform API Key (Access ID)
TUYA_CLOUD_API_SECRET=                       # Tuya IoT Platform API Secret (Access Secret)
TUYA_CLOUD_API_REGION=eu                     # Cloud region: eu, us, cn, in (default: eu)
EV_CHARGER_CLOUD_AMPS_CODE=Set32A            # Cloud DP code for amps (Set32A for 32A chargers, Set16A for 16A)

# ========================================
# TUYA HEAT PUMP OUTLET (with Temperature Sensor)
# ========================================
# Controls a Tuya-based smart outlet for the heat pump, using the built-in
# temperature sensor for schedule-based on/off decisions.
# Time slots define min/max temperature targets; the heat pump turns ON when
# below min and OFF when above max (with hysteresis in between).
# A solar override option keeps the heat pump running whenever excess solar
# export is available, regardless of temperature.
#
# To get your Device ID, IP, and Local Key, use the tinytuya wizard:
#   python -m tinytuya wizard

HEATPUMP_ENABLED=false                       # Enable Tuya heat pump control at startup (true/false)
HEATPUMP_DEVICE_ID=your_device_id            # Tuya Device ID (from tinytuya wizard)
HEATPUMP_IP=192.168.0.xxx                    # Outlet IP address on your local network
HEATPUMP_LOCAL_KEY=your_local_key            # Tuya Local Key (from tinytuya wizard)
HEATPUMP_PROTOCOL_VERSION=3.5               # Tuya protocol version (3.3, 3.4, or 3.5)
HEATPUMP_NAME=Heat Pump                      # Display name shown in the UI

# Tuya DPS Mapping (device model-specific)
HEATPUMP_DP_SWITCH=2                         # Data Point ID for relay state (read-only, controlled by thermostat)
HEATPUMP_DP_TEMPERATURE=6                    # Data Point ID for temp_current (e.g. 234 = 23.4°C)
HEATPUMP_DP_TEMP_SET=17                      # Data Point ID for target temperature setting
HEATPUMP_DP_HYSTERESIS=111                   # Data Point ID for hysteresis value
HEATPUMP_DP_MODE=4                           # Data Point ID for thermostat mode (heat/cool)
HEATPUMP_DP_TEMP_SCALE=10                    # Scale factor: 1=°C direct, 10=°C×10 (e.g. 234 = 23.4°C)
HEATPUMP_STANDBY_TARGET=-30                  # Target temp when no schedule active (very low = relay OFF)
HEATPUMP_SOLAR_OVERRIDE_TARGET=80            # Target temp during solar override (very high = relay ON)

# Solar Override — keep heat pump ON when excess solar is available
HEATPUMP_SOLAR_OVERRIDE=true                  # Enable solar override (true/false)
HEATPUMP_SOLAR_OVERRIDE_PRODUCTION_MIN=3000      # Minimum PV production (W) to trigger override ON (0 = disabled)
HEATPUMP_SOLAR_OVERRIDE_EXPORT_MIN=3000          # Minimum grid export (W) to trigger override ON (0 = disabled)
HEATPUMP_SOLAR_OVERRIDE_HP_POWER=3000         # Heat pump rated power (W) — stops if grid import > half
HEATPUMP_SOLAR_OVERRIDE_DELAY=60              # Seconds export/import must sustain before solar override activates/deactivates

# SOC-based overrides
HEATPUMP_SOC_ON_THRESHOLD=90                  # SOC >= this % → force heat pump ON
HEATPUMP_SOC_OFF_THRESHOLD=30                 # SOC <= this % → force heat pump OFF

# Voltage-based overrides (monitors target phase)
HEATPUMP_TARGET_PHASE=ANY                     # Phase to monitor for voltage triggers (L1/L2/L3/ANY)
HEATPUMP_HV_THRESHOLD=252.0                   # High voltage → dump ON (V)
HEATPUMP_HV_OFF_THRESHOLD=245.0               # HV hysteresis OFF threshold (V)
HEATPUMP_LV_THRESHOLD=210.0                   # Low voltage → shutdown (V)
HEATPUMP_LV_RECOVERY_VOLTAGE=220.0            # Voltage must exceed this for LV recovery (V)
HEATPUMP_LV_RECOVERY_DELAY=300                # Seconds voltage must stay above recovery level (default 5 min)
HEATPUMP_PHASE_CHANGE_DELAY=10                # Seconds of sustained HV/LV before voltage triggers activate

# Temperature Schedule Slots
# Format: HEATPUMP_SCHEDULE_N=HH:MM-HH:MM,min_temp,max_temp
# The thermostat is set to: target=max_temp, hysteresis=(max_temp - min_temp)
# Device firmware handles relay: ON when temp < min_temp, OFF when temp >= max_temp
HEATPUMP_SCHEDULE_1=06:00-16:00,28,35       # Daytime: maintain 28-35°C
HEATPUMP_SCHEDULE_2=16:00-18:00,40,45       # Peak hours: maintain 40-45°C
HEATPUMP_SCHEDULE_3=18:00-06:00,28,35       # Evening/night: maintain 28-35°C

# ========================================
# TAPO SMART PLUG OUTLETS
# ========================================
# Format: OUTLET_<N>_<PROPERTY> where N is the outlet number
# 
# PARAMETER EXPLANATIONS:
# 
# IP               - IP address of the Tapo P110 smart outlet on your network
# USER             - Tapo account email (must be OWNER account, not shared device)
# PASS             - Tapo account password
# NAME             - Display name shown in the UI
# PRIORITY         - Cascade priority (1=highest, turns on first. 2,3,etc turn on after higher priorities)
# POWER            - Estimated power consumption in Watts (DISPLAY ONLY - not used in startup logic)
# 
# START_SOC        - Battery % threshold: Turn ON when battery reaches this level (if other conditions met)
# STOP_SOC         - Battery % threshold: Turn OFF when battery drops below this level
# 
# HV_THRESHOLD     - High Voltage dump: Turn ON when monitored phase voltage reaches this level
# LV_THRESHOLD     - Low Voltage protection: Turn OFF when phase voltage drops below this level
# PHASE_CHANGE_DELAY - Seconds to wait before HV/LV voltage triggers activate (prevents brief spikes)
# 
# HEADROOM         - Minimum available power (Watts) needed to start this outlet
#                    System checks: (Max Phase Power - Current Load) >= HEADROOM before turning ON
#                    Example: Max=7000W, Current=500W, Headroom=1000W → Available=6500W ✓ Can start
# 
# TARGET_PHASE     - Which phase to monitor for voltage (L1, L2, L3, or ANY)
#                    ANY = monitors all phases: max voltage for HV turn-on, min voltage for LV turn-off
# 
# EXPORT_ACTIVE    - Enable/disable grid export dump feature (true/false)
# EXPORT_LIMIT     - Turn ON when grid export exceeds this many Watts (dumps excess solar to outlet)
# 
# RUNTIME_DELAY    - For priority 2+: Seconds higher priority outlets must run BEFORE this one can start
#                    Example: Priority 2 with RUNTIME_DELAY=300 waits 5 minutes after Priority 1 starts
#                    Priority 1 outlets ignore this parameter

# ===== OUTLET 1 - HEAT PUMP (HIGHEST PRIORITY) =====
OUTLET_1_IP=192.168.0.xxx
OUTLET_1_USER=your_email@example.com
OUTLET_1_PASS=your_password
OUTLET_1_NAME=Heat Pump
OUTLET_1_PRIORITY=1
OUTLET_1_POWER=3000

# SOC (State of Charge) Thresholds - Battery percentage triggers
OUTLET_1_START_SOC=70
OUTLET_1_STOP_SOC=32

# Voltage Thresholds - Phase voltage triggers
OUTLET_1_HV_THRESHOLD=252.0
OUTLET_1_LV_THRESHOLD=210.0
OUTLET_1_PHASE_CHANGE_DELAY=10

# Power Management
OUTLET_1_HEADROOM=1000
OUTLET_1_TARGET_PHASE=ANY

# Trigger Enable/Disable - Control which conditions can turn the outlet ON
OUTLET_1_SOC_ENABLED=true                    # Enable SOC-based trigger (uses START_SOC threshold)
OUTLET_1_VOLTAGE_ENABLED=true                # Enable voltage-based trigger (uses HV_THRESHOLD for ON, LV_THRESHOLD for OFF)
OUTLET_1_EXPORT_ENABLED=true                 # Enable export-based trigger (uses EXPORT_LIMIT threshold)

#SOC Control - Prevents rapid on/off cycling by enforcing a minimum time above the START_SOC threshold before turning on
OUTLET_1_SOC_DELAY=180                       # Seconds SOC must stay above start threshold before trigger fires (default 3 min)

# Export Control - Grid export triggers (only used if EXPORT_ENABLED=true)
OUTLET_1_EXPORT_LIMIT=5000
OUTLET_1_EXPORT_DELAY=300                    # Seconds export must sustain above limit before trigger fires (default 5 min)

# Restart Delay - Prevents rapid on/off cycling by enforcing a cooldown after outlet turns off
OUTLET_1_RESTART_DELAY_ENABLED=true          # Enable restart delay protection (true/false)
OUTLET_1_RESTART_DELAY_MINUTES=30            # Minutes to wait before auto-restarting after turn-off

# Cascade Delay (only affects priority 2+ outlets)
OUTLET_1_RUNTIME_DELAY=300

# ===== OUTLET 2 - EXTRA LOAD (SECOND PRIORITY) =====
# Uncomment these lines if you have a second outlet
#OUTLET_2_IP=192.168.0.xxx
#OUTLET_2_USER=your_email@example.com
#OUTLET_2_PASS=your_password
#OUTLET_2_NAME=Extra Load
#OUTLET_2_PRIORITY=2
#OUTLET_2_POWER=2000
#
## SOC Thresholds
#OUTLET_2_START_SOC=65
#OUTLET_2_STOP_SOC=35
#
## Voltage Thresholds
#OUTLET_2_HV_THRESHOLD=252.0
#OUTLET_2_LV_THRESHOLD=210.0
#OUTLET_2_PHASE_CHANGE_DELAY=10
#
## Power Management
#OUTLET_2_HEADROOM=3000
#OUTLET_2_TARGET_PHASE=ANY
#
## Trigger Enable/Disable - Control which conditions can turn the outlet ON
#OUTLET_2_SOC_ENABLED=true                    # Enable SOC-based trigger (uses START_SOC threshold)
#OUTLET_2_VOLTAGE_ENABLED=true                # Enable voltage-based trigger (uses HV_THRESHOLD for ON, LV_THRESHOLD for OFF)
#OUTLET_2_EXPORT_ENABLED=true                 # Enable export-based trigger (uses EXPORT_LIMIT threshold)
#
## Export Control - Grid export triggers (only used if EXPORT_ENABLED=true)
#OUTLET_2_EXPORT_LIMIT=3000
#
## Cascade Delay - IMPORTANT: Priority 2 waits for Priority 1 to run first
#OUTLET_2_RUNTIME_DELAY=300                   # Seconds Priority 1 must run BEFORE this outlet can start (300s = 5 minutes)

# ========================================
# PARAMETER EXPLANATIONS
# ========================================
#
# IP               - IP address of the Tapo P110 smart outlet on your network
# USER             - Tapo account email (must be OWNER account, not shared device)
# PASS             - Tapo account password
# NAME             - Display name shown in the UI
# PRIORITY         - Cascade priority (1=highest, turns on first. 2,3,etc turn on after higher priorities)
# POWER            - Estimated power consumption in Watts (DISPLAY ONLY - not used in startup logic)
# 
# START_SOC        - Battery % threshold: Turn ON when battery reaches this level (if SOC_ENABLED=true)
# STOP_SOC         - Battery % threshold: Turn OFF when battery drops below this level
# 
# HV_THRESHOLD     - High Voltage dump: Turn ON when monitored phase voltage reaches this level (if VOLTAGE_ENABLED=true)
# LV_THRESHOLD     - Low Voltage protection: Turn OFF when phase voltage drops below this level
# PHASE_CHANGE_DELAY - Seconds to wait before HV/LV voltage triggers activate (prevents brief spikes)
# 
# HEADROOM         - Minimum available power (Watts) needed to start this outlet
#                    System checks: (Max Phase Power - Current Load) >= HEADROOM before turning ON
#                    Example: Max=7000W, Current=500W, Headroom=1000W → Available=6500W ✓ Can start
# 
# TARGET_PHASE     - Which phase to monitor for voltage (L1, L2, L3, or ANY)
#                    ANY = monitors all phases: max voltage for HV turn-on, min voltage for LV turn-off
# 
# SOC_ENABLED      - Enable/disable SOC-based trigger (true/false)
# VOLTAGE_ENABLED  - Enable/disable voltage-based trigger (true/false)
# EXPORT_ENABLED   - Enable/disable grid export dump feature (true/false)
# 
# EXPORT_LIMIT     - Turn ON when grid export exceeds this many Watts (only if EXPORT_ENABLED=true)
# 
# RUNTIME_DELAY    - For priority 2+: Seconds higher priority outlets must run BEFORE this one can start
#                    Example: Priority 2 with RUNTIME_DELAY=300 waits 5 minutes after Priority 1 starts
#                    Priority 1 outlets ignore this parameter
